---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { SITE, CTA, FACTS, SHOW_SIGNUP_CTA } from "../consts";
import { organization, breadcrumb, person } from "../schema";
import { AUTHORS } from "../authors";

const title = "About PlaceMate — the planner for UK student nurses";
const description =
  "PlaceMate is an independent app built in the UK to help student nurses stay organised across placement — tracking hours, NMC proficiencies, skills and reflections in one place. Not affiliated with the NMC.";

const nicola = AUTHORS["nicola-nightingale"];

const jsonLd = [
  organization(),
  person(nicola),
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "About", path: "/about" },
  ]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">About</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      Made for student nurses, built around the NMC standards
    </h1>

    <div class="mt-8 space-y-5 text-lg leading-relaxed text-slate-600">
      <p>
        PlaceMate is an independent app for UK student nurses. It started from a simple problem:
        student nurses juggle placement hours, NMC proficiencies, clinical skills, medications,
        reflections and revision across notebooks, spreadsheets and a scatter of apps — and
        important evidence falls through the cracks.
      </p>
      <p>
        PlaceMate brings it into one place. Everything is modelled on the
        <strong class="font-semibold text-slate-800">{FACTS.nmcStandard}</strong> ({FACTS.nmcYear}):
        the {FACTS.practiceHours.toLocaleString("en-GB")}-hour practice requirement, all {FACTS.proficiencies}
        proficiency statements across {FACTS.platforms} platforms, and the Annexe B nursing
        procedures. So what you record lines up with what your programme assesses.
      </p>
      <p>
        We're building student-first — free, private, and useful from your very first placement —
        and adult-field nursing is our starting point. It's early days, and we're shaping PlaceMate
        alongside the students and educators who use it.
      </p>
    </div>

    <section id="nicola-nightingale" class="mt-12 scroll-mt-24 rounded-2xl border border-slate-200 p-6">
      <h2 class="text-base font-semibold uppercase tracking-wider text-emerald-600">
        Clinical accuracy
      </h2>
      <p class="mt-3 text-xl font-bold tracking-tight text-ink">
        {nicola.name}, {nicola.credential}
      </p>
      <p class="text-sm font-medium text-slate-500">{nicola.role}</p>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        {nicola.name} is a Registered Nurse and PlaceMate co-founder, and leads clinical
        review of PlaceMate's guides. Our guides are written around the published
        {FACTS.nmcStandard} ({FACTS.nmcYear}), and any guide carrying a clinical-review
        byline has been checked by a Registered Nurse — so what you read lines up with what
        your programme expects.
      </p>
    </section>

    <div class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-base font-semibold text-ink">A note on independence</h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">
        PlaceMate is not affiliated with, or endorsed by, the Nursing and Midwifery Council. We
        reference the NMC's published standards to help you organise your practice learning; always
        follow your own university's guidance and Practice Assessment Document.
      </p>
    </div>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      {SHOW_SIGNUP_CTA && <Button href={CTA.signup.href} external>{CTA.signup.label}</Button>}
      <Button href={`mailto:${SITE.email}`} variant="secondary">Contact us</Button>
    </div>
  </article>
</Layout>
