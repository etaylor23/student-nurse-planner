---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { SITE } from "../consts";
import { organization, breadcrumb } from "../schema";

const title = "Contact PlaceMate";
const description =
  "Get in touch with PlaceMate — for student nurses, universities and practice-placement teams. Email hello@placemate.uk.";

const jsonLd = [
  organization(),
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "Contact", path: "/contact" },
  ]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-2xl px-4 py-16 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Contact</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">Get in touch</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-slate-600">
      Questions, feedback, or an idea for how PlaceMate could help your placement or cohort? We read
      every message.
    </p>
    <div class="mt-8">
      <Button href={`mailto:${SITE.email}`}>Email {SITE.email}</Button>
    </div>
    <div class="mt-12 grid gap-4 text-left sm:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-base font-semibold text-ink">Student nurses</h2>
        <p class="mt-2 text-sm text-slate-600">
          Found a bug or want a feature? Tell us — PlaceMate is shaped by the students who use it.
        </p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-base font-semibold text-ink">Universities</h2>
        <p class="mt-2 text-sm text-slate-600">
          Course leaders and placement teams: see
          <a href="/for-universities" class="font-medium text-emerald-700 hover:text-emerald-800"
            >PlaceMate for universities</a
          > or email us directly.
        </p>
      </div>
    </div>
  </section>
</Layout>
