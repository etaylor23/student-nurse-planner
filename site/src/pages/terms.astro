---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../consts";
import { breadcrumb } from "../schema";

const title = "Terms of Use | PlaceMate";
const description =
  "The terms for using PlaceMate — an independent study and organisation tool for UK student nurses, provided as-is and not a substitute for your university's guidance or clinical judgement.";
const updated = "12 July 2026";

const jsonLd = [
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "Terms", path: "/terms" },
  ]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900">Terms of Use</h1>
    <p class="mt-2 text-sm text-slate-500">Last updated {updated}</p>

    <div class="mt-8 space-y-8 text-slate-600">
      <section>
        <h2 class="text-lg font-semibold text-slate-900">About PlaceMate</h2>
        <p class="mt-2 leading-relaxed">
          PlaceMate is an independent tool that helps UK student nurses organise their studies and
          placement learning. By using the website or app you agree to these terms.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Not clinical advice, not an NMC service</h2>
        <p class="mt-2 leading-relaxed">
          PlaceMate is a study and organisation aid. It is not medical or clinical advice and does
          not replace your professional judgement, your practice supervisors, or your university's
          requirements and Practice Assessment Document. PlaceMate is not affiliated with, or
          endorsed by, the Nursing and Midwifery Council. Always follow your programme's official
          guidance; where they differ, your university's guidance takes precedence.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Acceptable use</h2>
        <p class="mt-2 leading-relaxed">
          Use PlaceMate lawfully and keep patient-identifiable information out of the app in line
          with your confidentiality obligations. Don't misuse, disrupt, or attempt to gain
          unauthorised access to the service.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Provided "as is"</h2>
        <p class="mt-2 leading-relaxed">
          PlaceMate is provided as-is, without warranties, during early access. We may change or
          discontinue features. To the extent permitted by law, we are not liable for loss arising
          from use of the service — keep your own records of anything important to your programme.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Contact</h2>
        <p class="mt-2 leading-relaxed">
          Questions about these terms? Email
          <a href={`mailto:${SITE.email}`} class="text-emerald-700 hover:underline">{SITE.email}</a>.
        </p>
      </section>
    </div>
  </article>
</Layout>
