---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { SITE, FACTS } from "../consts";
import { organization, breadcrumb } from "../schema";

const title = "PlaceMate for universities — practice placement support";
const description =
  "PlaceMate helps nursing students arrive at placement organised and evidence-ready, aligned to the NMC proficiencies. Exploring partnerships with UK universities and practice-placement teams.";

const jsonLd = [
  organization(),
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "For universities", path: "/for-universities" },
  ]),
];

const points = [
  {
    icon: "hours",
    title: "Students who stay on top of their hours",
    body: `Learners track their ${FACTS.practiceHours.toLocaleString("en-GB")} practice hours as they go, so hours conversations at progression points are quicker and better evidenced.`,
  },
  {
    icon: "proficiency",
    title: "Aligned to the NMC proficiencies",
    body: `The proficiency and skills tracking follows the ${FACTS.nmcStandard} — all ${FACTS.proficiencies} statements and the Annexe B procedures — so it complements your Practice Assessment Document rather than competing with it.`,
  },
  {
    icon: "reflection",
    title: "Reflective, confidentiality-aware practice",
    body: "Guided Gibbs reflections with a standing patient-confidentiality reminder help build good habits from day one.",
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 pt-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">For universities</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      Placement support that starts with the student
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-slate-600">
      PlaceMate is student-first today: individual nurses use it free to stay organised across
      placement. For course leaders and practice-placement teams, that means learners who arrive
      engaged, evidence-ready and aligned to the NMC standards.
    </p>
    <div class="mt-8">
      <Button href={`mailto:${SITE.email}?subject=PlaceMate%20for%20universities`}>
        Talk to us about your cohort
      </Button>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-6 md:grid-cols-3">
      {
        points.map((p) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <Icon name={p.icon} />
            </div>
            <h2 class="mt-4 text-lg font-semibold text-ink">{p.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight text-ink">
        Exploring institutional partnerships
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">
        We're working with student nurses first and building toward cohort-level features for
        universities. If you help run a nursing programme or practice placements and want to shape
        what comes next, we'd love to hear from you.
      </p>
      <div class="mt-7">
        <Button href={`mailto:${SITE.email}?subject=PlaceMate%20partnership`}>
          Get in touch
        </Button>
      </div>
    </div>
  </section>
</Layout>
