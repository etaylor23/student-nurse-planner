---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { SITE, CTA, SHOW_SIGNUP_CTA } from "../consts";
import { breadcrumb } from "../schema";

const title = "Pricing — Placemate is free for student nurses";
const description =
  "Placemate is free for UK student nurses — every feature, no card required. See what's included and how the free plan works.";

const included = [
  "Placement hours tracker",
  "NMC proficiency tracker (all 219 statements)",
  "Clinical skills passport (NMC Annexe B)",
  "Weekly shift planner",
  "Medication notes & drug-calculation practice",
  "Guided Gibbs reflections",
  "Revision timetable",
  "Self-care check-ins",
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: SITE.name,
    description,
    brand: { "@type": "Brand", name: SITE.name },
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "GBP",
      availability: "https://schema.org/InStock",
      url: SITE.appUrl,
    },
  },
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "Pricing", path: "/pricing" },
  ]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 pt-16 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">Pricing</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      Free for student nurses
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-slate-600">
      Every feature, no card required. We're focused on helping students first — so the student
      plan is, and stays, free.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 md:grid-cols-2">
      <!-- Student plan -->
      <div class="rounded-3xl border-2 border-emerald-500 bg-white p-8 shadow-sm">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-ink">Student</h2>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
            Free
          </span>
        </div>
        <p class="mt-4 text-4xl font-bold text-ink">£0</p>
        <p class="mt-1 text-sm text-slate-500">forever, for individual student nurses</p>
        {
          SHOW_SIGNUP_CTA ? (
            <Button href={CTA.signup.href} external class="mt-6 w-full">{CTA.signup.label}</Button>
          ) : (
            <Button href={CTA.demo.href} external class="mt-6 w-full">{CTA.demo.label}</Button>
          )
        }
        <ul class="mt-6 space-y-2.5">
          {
            included.map((item) => (
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-emerald-500"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m5 13 4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Universities -->
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8">
        <h2 class="text-lg font-semibold text-ink">Universities</h2>
        <p class="mt-4 text-2xl font-bold text-ink">Let's talk</p>
        <p class="mt-1 text-sm text-slate-500">cohort features for nursing programmes</p>
        <Button
          href={`mailto:${SITE.email}?subject=Placemate%20for%20universities`}
          variant="secondary"
          class="mt-6 w-full"
        >
          Contact us
        </Button>
        <p class="mt-6 text-sm leading-relaxed text-slate-600">
          We're building toward tools for course leaders and practice-placement teams. If you'd like
          to help shape them for your cohort, get in touch — see
          <a href="/for-universities" class="font-medium text-emerald-700 hover:text-emerald-800">
            Placemate for universities</a
          >.
        </p>
      </div>
    </div>

    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-slate-500">
      Placemate is in early access. You can start instantly in demo mode on your device, or create a
      free account to sync across devices.
    </p>
  </section>
</Layout>
