---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import FeatureCard from "../components/FeatureCard.astro";
import Faq from "../components/Faq.astro";
import CtaSection from "../components/CtaSection.astro";
import Icon from "../components/Icon.astro";
import { SITE, CTA, FACTS } from "../consts";
import { FEATURES } from "../data/features";
import { FAQS } from "../data/faqs";
import { organization, website, webApplication, faqPage } from "../schema";

const title = "Placemate — the planner for UK student nurses";
const description = SITE.description;

const homeFeatures = FEATURES.filter((f) => f.home);
const homeFaqs = FAQS.filter((f) => f.home);

const stats = [
  { value: "2,300", label: "practice hours tracked" },
  { value: "219", label: "NMC proficiencies" },
  { value: "7", label: "NMC platforms" },
  { value: "£0", label: "free for students" },
];

const jsonLd = [organization(), website(), webApplication(), faqPage(homeFaqs)];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-emerald-50/70 to-white"
    >
    </div>
    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
      <div class="max-w-xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600">
          For UK student nurses
        </p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
          The student nurse planner built around the NMC standards
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-slate-600">
          Placemate helps you track placement hours, log your NMC proficiencies, plan shifts and
          revision, and practise drug calculations — all in one free app, on any device.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={CTA.signup.href} external class="w-full sm:w-auto">{CTA.signup.label}</Button>
          <Button href={CTA.demo.href} external variant="secondary" class="w-full sm:w-auto">
            {CTA.demo.label}
          </Button>
        </div>
        <p class="mt-4 text-sm text-slate-500">Free • no card • start in demo mode instantly</p>
      </div>

      <!-- Hero illustration: a CSS-only "hours progress" card. -->
      <div class="lg:justify-self-end">
        <div class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white p-6 shadow-xl">
          <div class="flex items-center justify-between">
            <p class="text-sm font-semibold text-ink">Practice hours</p>
            <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700">
              On track
            </span>
          </div>
          <div class="mt-4">
            <div class="flex items-end justify-between">
              <p class="text-3xl font-bold text-ink">1,472<span class="text-lg font-medium text-slate-400"> / 2,300</span></p>
              <p class="text-sm text-slate-500">64%</p>
            </div>
            <div class="mt-2 h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
              <div class="h-full w-[64%] rounded-full bg-emerald-500"></div>
            </div>
            <p class="mt-2 text-xs text-slate-400">828 hours to go · 120 simulated of 600</p>
          </div>
          <div class="mt-6 space-y-2">
            {
              [
                { p: "1.1 Accountable practice", s: "Achieved" },
                { p: "3.2 Assessing needs", s: "Developing" },
                { p: "4.14 Medicines numeracy", s: "Achieved" },
              ].map((row) => (
                <div class="flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
                  <span class="text-xs font-medium text-slate-600">{row.p}</span>
                  <span
                    class:list={[
                      "text-[11px] font-semibold",
                      row.s === "Achieved" ? "text-emerald-600" : "text-sky-600",
                    ]}
                  >
                    {row.s}
                  </span>
                </div>
              ))
            }
          </div>
          <p class="mt-4 text-center text-[11px] text-slate-400">Illustration of the app</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 py-8 sm:px-6 md:grid-cols-4">
      {
        stats.map((s) => (
          <div class="text-center">
            <p class="text-2xl font-bold text-ink sm:text-3xl">{s.value}</p>
            <p class="mt-1 text-sm text-slate-500">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Features -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-ink">
        Everything a student nurse needs to stay on track
      </h2>
      <p class="mt-3 text-slate-600">
        Purpose-built for the UK nursing degree — from your first placement to registration.
      </p>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {homeFeatures.map((feature) => <FeatureCard feature={feature} />)}
    </div>
    <div class="mt-8">
      <a href="/features" class="text-sm font-semibold text-emerald-700 hover:text-emerald-800">
        See all features →
      </a>
    </div>
  </section>

  <!-- Why Placemate -->
  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="grid gap-8 md:grid-cols-3">
        {
        [
          {
            icon: "proficiency",
            title: "Built on the NMC standards",
            body: `Hours, proficiencies and skills all follow the ${FACTS.nmcStandard} — so what you track is what your programme assesses.`,
          },
          {
            icon: "planner",
            title: "One place, not five apps",
            body: "Hours, shifts, proficiencies, skills, medications, reflections and revision — connected, so evidence flows between them.",
          },
          {
            icon: "wellbeing",
            title: "Private by design",
            body: "No patient-identifiable data, cookieless analytics, and a demo mode that keeps everything on your device.",
          },
        ].map((b) => (
            <div>
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white text-emerald-600 shadow-sm">
                <Icon name={b.icon} />
              </div>
              <h3 class="mt-4 text-lg font-semibold text-ink">{b.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{b.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-ink">Common questions</h2>
    <div class="mt-8"><Faq faqs={homeFaqs} /></div>
    <div class="mt-6">
      <a href="/faq" class="text-sm font-semibold text-emerald-700 hover:text-emerald-800">
        Read all FAQs →
      </a>
    </div>
  </section>

  <CtaSection />
</Layout>
