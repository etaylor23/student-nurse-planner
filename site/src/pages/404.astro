---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { CTA } from "../consts";

const title = "Page not found | Placemate";
const description = "That page could not be found.";
---

<Layout title={title} description={description} noindex>
  <section class="mx-auto flex max-w-xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <p class="text-6xl font-bold text-emerald-600">404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink">Page not found</h1>
    <p class="mt-3 text-slate-600">
      The page you're looking for doesn't exist or has moved. Let's get you back on track.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <Button href="/">Back to home</Button>
      <Button href="/features" variant="secondary">Browse features</Button>
      <Button href={CTA.demo.href} external variant="secondary">{CTA.demo.label}</Button>
    </div>
  </section>
</Layout>
