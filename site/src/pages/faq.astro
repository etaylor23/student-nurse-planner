---
import Layout from "../layouts/Layout.astro";
import Faq from "../components/Faq.astro";
import CtaSection from "../components/CtaSection.astro";
import { FAQS } from "../data/faqs";
import { faqPage, breadcrumb } from "../schema";

const title = "FAQ — placement hours, NMC proficiencies & more | PlaceMate";
const description =
  "Answers for UK student nurses: how many placement hours you need, what the NMC proficiencies are, what a PAD is, how to write a reflection, how to pass drug calculations, and whether PlaceMate is free.";

const jsonLd = [
  faqPage(FAQS),
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "FAQ", path: "/faq" },
  ]),
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <span class="block text-sm font-semibold uppercase tracking-wider text-emerald-600">FAQ</span>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      Frequently asked questions
    </h1>
    <p class="mt-5 text-lg text-slate-600">
      Straight answers about nursing placements, the NMC standards and how PlaceMate helps.
    </p>
    <div class="mt-10"><Faq faqs={FAQS} /></div>
  </section>

  <CtaSection />
</Layout>
