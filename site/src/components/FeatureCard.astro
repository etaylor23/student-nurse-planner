---
import Icon from "./Icon.astro";
import type { Feature } from "../data/features";
interface Props {
  feature: Feature;
}
const { feature } = Astro.props;
---

<article class="rounded-2xl border border-slate-200 bg-white p-6 transition hover:shadow-md">
  <div
    class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600"
  >
    <Icon name={feature.icon} />
  </div>
  <h3 class="mt-4 text-base font-semibold text-slate-900">{feature.name}</h3>
  <p class="mt-1 text-sm font-medium text-emerald-700">{feature.tagline}</p>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{feature.body}</p>
</article>
