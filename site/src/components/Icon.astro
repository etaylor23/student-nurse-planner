---
// Small stroke icon set (currentColor). Names match Feature.icon in data/features.ts.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "h-6 w-6" } = Astro.props;

const paths: Record<string, string> = {
  hours: "M12 7v5l3 2M12 21a9 9 0 1 1 0-18 9 9 0 0 1 0 18Z",
  planner:
    "M8 3v3M16 3v3M4 9h16M5 6h14a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z",
  proficiency: "M9 12l2 2 4-4M8 4h8a2 2 0 0 1 2 2v13a1 1 0 0 1-1.5.9L12 19l-4.5 1.9A1 1 0 0 1 6 20V6a2 2 0 0 1 2-2Z",
  skills: "M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11",
  meds: "M10.5 20.5a5 5 0 0 1-7-7l6-6a5 5 0 0 1 7 7l-6 6ZM8 8l8 8",
  reflection: "M12 7c-1.5-1.3-3.5-2-6-2v13c2.5 0 4.5.7 6 2 1.5-1.3 3.5-2 6-2V5c-2.5 0-4.5.7-6 2Zm0 0v13",
  revision: "M22 10 12 5 2 10l10 5 10-5ZM6 12v5c0 1 2.7 2.5 6 2.5s6-1.5 6-2.5v-5",
  wellbeing:
    "M20.8 6.6a5 5 0 0 0-7.1 0L12 8.3l-1.7-1.7a5 5 0 0 0-7.1 7.1l1.7 1.7L12 22.4l7.1-7.1 1.7-1.7a5 5 0 0 0 0-7Z",
};
const d = paths[name] ?? paths.proficiency;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={d}></path>
</svg>
