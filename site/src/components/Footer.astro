---
import Logo from "./Logo.astro";
import { SITE, CTA, SHOW_SIGNUP_CTA } from "../consts";

const year = new Date().getFullYear();

const cols = [
  {
    title: "Product",
    links: [
      { href: "/features", label: "Features" },
      { href: "/pricing", label: "Pricing" },
      { href: "/faq", label: "FAQ" },
      { href: "/for-universities", label: "For universities" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "/contact", label: "Contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy", label: "Privacy" },
      { href: "/terms", label: "Terms" },
    ],
  },
];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="max-w-xs">
        <a href="/" class="flex items-center" aria-label="Placemate home"><Logo /></a>
        <p class="mt-3 text-sm text-slate-500">{SITE.tagline}.</p>
        {
          SHOW_SIGNUP_CTA && (
            <a
              href={CTA.signup.href}
              rel="noopener"
              class="mt-4 inline-flex text-sm font-semibold text-emerald-700 hover:text-emerald-800"
            >
              {CTA.signup.label} →
            </a>
          )
        }
      </div>
      {
        cols.map((col) => (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400">
              {col.title}
            </h2>
            <ul class="mt-3 space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-slate-600 hover:text-emerald-700">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div
      class="mt-10 flex flex-col gap-2 border-t border-slate-200 pt-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Placemate. Made in the UK for student nurses.</p>
      <p>
        Not affiliated with the Nursing and Midwifery Council (NMC). <a
          href={`mailto:${SITE.email}`}
          class="hover:text-emerald-700">{SITE.email}</a
        >
      </p>
    </div>
  </div>
</footer>
