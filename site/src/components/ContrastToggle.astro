---
// High-contrast (WCAG AAA, 7:1) theme toggle. A real button with aria-pressed; the
// click handler + persistence live in Layout.astro (shared by every .js-contrast-toggle).
// aria-pressed is set to the correct initial state on load by that script.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<button
  type="button"
  class:list={[
    "js-contrast-toggle inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg border border-slate-300 text-slate-700 transition hover:bg-slate-50",
    className,
  ]}
  aria-pressed="false"
  aria-label="High-contrast mode"
  title="High-contrast mode"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
    <path d="M12 3a9 9 0 0 0 0 18Z" fill="currentColor"></path>
  </svg>
  <span class="sr-only">Toggle high-contrast mode</span>
</button>
