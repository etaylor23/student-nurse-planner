---
// PlaceMate wordmark: an emerald rounded-square "pin + check" mark next to the name.
// `markOnly` reuses just the badge (e.g. compact header on mobile). The same mark art
// lives in public/favicon.svg and the OG generator (scripts/gen-og.mjs) — keep in sync.
interface Props {
  class?: string;
  markOnly?: boolean;
}
const { class: className = "", markOnly = false } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg
    width="28"
    height="28"
    viewBox="0 0 32 32"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="shrink-0"
  >
    <rect width="32" height="32" rx="8" fill="#059669"></rect>
    <path
      d="M16 7c-3.6 0-6.5 2.9-6.5 6.5 0 4.4 5.3 9.6 6 10.2.3.3.7.3 1 0 .7-.6 6-5.8 6-10.2C22.5 9.9 19.6 7 16 7Z"
      fill="#fff"
      fill-opacity="0.22"></path>
    <path
      d="m12.7 13.6 2.3 2.3 4.3-4.6"
      stroke="#fff"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
  {
    !markOnly && (
      <span class="text-lg font-semibold tracking-tight text-slate-900">
        Place<span class="text-emerald-600">Mate</span>
      </span>
    )
  }
</span>
