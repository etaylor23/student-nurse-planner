# Public Cognito client config for the SPA (safe to commit — these are NOT secrets,
# they are baked into the client bundle). Copy to `.env.local` for `npm run dev`.
VITE_COGNITO_REGION=eu-west-2
VITE_COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# RPC API base — defaults to "/api" (same-origin via CloudFront / the Vite dev proxy).
VITE_API_BASE=/api
