{
  "name": "student-nurse-planner-infra",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK app for the Student Nurse Planner backend (auth + DynamoDB). See ../spec/spec-implementation-roadmap.md.",
  "bin": {
    "infra": "bin/app.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "cdk:synth": "cdk synth",
    "cdk:diff:dev": "cdk diff NursePlanner-dev --profile personal",
    "cdk:diff:prod": "cdk diff NursePlanner-prod --profile personal",
    "cdk:deploy:dev": "cdk deploy NursePlanner-dev --profile personal",
    "cdk:deploy:prod": "cdk deploy NursePlanner-prod --profile personal",
    "bootstrap": "cdk bootstrap --profile personal"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.19.21",
    "aws-cdk": "^2.1129.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "amazon-cognito-passwordless-auth": "^0.17.0",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1"
  }
}
