{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AssumeCdkBootstrapRoles",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": "arn:aws:iam::641364901830:role/cdk-hnb659fds-*"
    },
    {
      "Sid": "ReadStackOutputsForFrontendDeploy",
      "Effect": "Allow",
      "Action": "cloudformation:DescribeStacks",
      "Resource": "arn:aws:cloudformation:eu-west-2:641364901830:stack/NursePlanner-*/*"
    },
    {
      "Sid": "PublishSpaToWebBuckets",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::nurse-planner-web-*", "arn:aws:s3:::nurse-planner-web-*/*"]
    },
    {
      "Sid": "PublishMarketingSite",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::placemate-marketing-*", "arn:aws:s3:::placemate-marketing-*/*"]
    },
    {
      "Sid": "InvalidateCloudFront",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "*"
    }
  ]
}
